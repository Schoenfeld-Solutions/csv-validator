---
import {
  basePath,
  otherLocale,
  routeFor,
  siteCopy,
  type Locale,
  type PageKey,
} from "../lib/i18n";

type Props = {
  activePage?: PageKey;
  locale: Locale;
};

const { activePage = "home", locale } = Astro.props;
const copy = siteCopy[locale];
const alternateLocale = otherLocale(locale);
const baseUrl = import.meta.env.BASE_URL;
const hrefFor = (page: PageKey, targetLocale: Locale = locale) =>
  basePath(baseUrl, routeFor(targetLocale, page));
const isActive = (page: PageKey) => activePage === page;
const switchHref = hrefFor(activePage, alternateLocale);
const githubUrl = "https://github.com/Schoenfeld-Solutions/csv-validator";
---

<a class="skip-link" href="#main-content">{copy.skipToContent}</a>
<header class="site-header">
  <a class="brand" href={hrefFor("home")} aria-label={copy.brand}>
    <svg class="brand-logo" viewBox="0 0 48 48" aria-hidden="true" fill="none">
      <path
        d="M13 5.5h16.5L39 15v27.5H13z"
        stroke="currentColor"
        stroke-width="2.4"
        stroke-linejoin="round"></path>
      <path d="M29 5.5V15h10" stroke="currentColor" stroke-width="2.4"></path>
      <path
        d="M19 22h14M19 28h14M19 34h8"
        stroke="currentColor"
        stroke-width="2.4"
        stroke-linecap="round"></path>
      <path
        d="m29.5 35 3 3 6-7"
        stroke="currentColor"
        stroke-width="2.6"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
    <span>{copy.brand}</span>
  </a>

  <nav class="site-nav" aria-label="Primary navigation">
    <a
      href={hrefFor("home")}
      aria-current={isActive("home") ? "page" : undefined}>{copy.nav.home}</a
    >
    <a
      href={hrefFor("formats")}
      aria-current={isActive("formats") ? "page" : undefined}
      >{copy.nav.formats}</a
    >
  </nav>

  <div class="header-actions">
    <a
      class="icon-link language-link"
      href={switchHref}
      aria-label={copy.languageSwitch}
      title={copy.languageSwitch}>{copy.languageSwitchLabel}</a
    >
    <a
      class="icon-link"
      href={githubUrl}
      aria-label={copy.github}
      title={copy.github}
    >
      <svg
        width="24"
        height="24"
        fill="none"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path stroke="none" d="M0 0h24v24H0z"></path>
        <path
          d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0C6.5 2.8 5.4 3.1 5.4 3.1a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 4 9.5c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V21"
        ></path>
      </svg>
    </a>
    <button
      class="theme-toggle"
      id="themeToggle"
      type="button"
      aria-label={copy.theme}
      aria-pressed="false"
      title={copy.theme}
    >
      <svg
        class="theme-icon theme-icon-sun"
        width="24"
        height="24"
        fill="none"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path stroke="none" d="M0 0h24v24H0z"></path>
        <path
          d="M14.828 14.828a4 4 0 1 0-5.656-5.656 4 4 0 0 0 5.656 5.656M6.343 17.657l-1.414 1.414M6.343 6.343 4.929 4.929M17.657 6.343l1.414-1.414M17.657 17.657l1.414 1.414M4 12H2M12 4V2M20 12h2M12 20v2"
        ></path>
      </svg>
      <svg
        class="theme-icon theme-icon-moon"
        width="24"
        height="24"
        fill="none"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path stroke="none" d="M0 0h24v24H0z"></path>
        <path d="M12 3h.393a7.5 7.5 0 0 0 7.92 12.446A9 9 0 1 1 12 2.992z"
        ></path>
      </svg>
    </button>
  </div>
</header>
